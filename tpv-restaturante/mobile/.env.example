# Configuración de conexión al backend y servicios externos
# Variables de entorno para Expo (EXPO_PUBLIC_* están disponibles en el código cliente)

# URL del servidor Next.js (cambiar por la IP real del servidor)
EXPO_PUBLIC_API_URL=http://192.168.1.100:3000

# Clave API compartida (debe coincidir con TPV_API_KEY del servidor)
# En producción, inyectar via EAS Secrets o CI/CD, nunca en app.json
EXPO_PUBLIC_TPV_API_KEY=1234

# Supabase Realtime (mismos valores que en .env del backend)
EXPO_PUBLIC_SUPABASE_URL=https://usrdtucgeogytnxyivoy.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_yOlWsu92RrtMllJMcKyV_Q_Nr12lm5h

# Stripe (clave pública para pagos en cliente)
EXPO_PUBLIC_STRIPE_PK=pk_test_51TU91h5ff9CDRTTdOpqVS5bZEMUA4rStbQoQStq1lN2FkD2iB8YjDXV2QUzoGpTd957ncWfaybL2HS18N0OB2Ol500R3lHjspP

