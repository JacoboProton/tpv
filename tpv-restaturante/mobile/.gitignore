# .easignore

# Dependencies
node_modules/

# Native builds
android/
ios/
.gradle/
build/

# Expo / Metro caches
.expo/
.expo-shared/
dist/
web-build/

# Tests & dev
__tests__/
coverage/
.eslintcache

# Environment files
.env
.env.local
.env.*.local

# OS / IDE
.DS_Store
.idea/
.vscode/
*.swp

# Logs
npm-debug.*
yarn-debug.log*
yarn-error.log*
*.log

# Git metadata
.git/

# Credentials (never upload)
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.cer

# TypeScript build artifacts
*.tsbuildinfo
expo-env.d.ts

# Parent monorepo (excludes the Next.js web project from mobile builds)
../app/
../components/
../lib/
../__tests__/
../public/
../.next/
../node_modules/
../scripts/
../download/
../package-lock.json
../package.json