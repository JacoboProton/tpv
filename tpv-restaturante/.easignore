# Exclude everything at repo root except mobile/
/*
!/mobile

# Inside mobile/, replicate mobile/.gitignore
mobile/node_modules/
mobile/android/
mobile/ios/
mobile/.gradle/
mobile/build/
mobile/.expo/
mobile/.expo-shared/
mobile/dist/
mobile/web-build/
mobile/__tests__/
mobile/coverage/
mobile/.eslintcache
mobile/.env
mobile/.env.local
mobile/.env.*.local
mobile/.DS_Store
mobile/.idea/
mobile/.vscode/
mobile/*.swp
mobile/npm-debug.*
mobile/yarn-debug.log*
mobile/yarn-error.log*
mobile/*.log
mobile/.git/
mobile/*.jks
mobile/*.p8
mobile/*.p12
mobile/*.key
mobile/*.mobileprovision
mobile/*.cer
mobile/*.tsbuildinfo
mobile/expo-env.d.ts
