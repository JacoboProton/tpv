# Base de datos (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Supabase Realtime — sincronización KDS/POS en tiempo real
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_tu_key_aqui

# Fiskaly — Verifactu (facturación electrónica AEAT)
FISKALY_ENVIRONMENT=TEST
FISKALY_API_KEY=api_key_aqui
FISKALY_API_SECRET=api_secret_aqui
FISKALY_TAXPAYER_NIF=78406450W
FISKALY_TERRITORY=CANARY_ISLANDS

# Stripe — pagos con tarjeta
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...  # Lo obtienes en dashboard.stripe.com → Webhooks
UBER_WEBHOOK_SECRET=             # Secreto del webhook de UberEats
GLOVO_WEBHOOK_SECRET=            # Secreto del webhook de Glovo

# Stripe Terminal — ubicación NFC (por defecto: La Comanda, Restaurante, Ciudad, ES, 28001)
STRIPE_LOCATION_NAME=Mi Restaurante
STRIPE_LOCATION_LINE1=Calle Mayor 1
STRIPE_LOCATION_CITY=Madrid
STRIPE_LOCATION_STATE=Madrid
STRIPE_LOCATION_COUNTRY=ES
STRIPE_LOCATION_POSTAL_CODE=28013

# API Key — protección rutas /api/*
TPV_API_KEY=cambia_esto_por_una_clave_segura
NEXT_PUBLIC_TPV_API_KEY=cambia_esto_por_una_clave_segura

# CORS — origenes permitidos para llamadas a /api/*
# Lista separada por comas. Usar * para permitir cualquier origen (solo desarrollo).
# Ejemplo: https://tudominio.com,https://admin.tudominio.com
ALLOWED_ORIGINS=*

# CRON — secreto para backup automático
CRON_SECRET=1234

# SMTP — envío de facturas por email
# Opción A: Gmail (requiere contraseña de aplicación en https://myaccount.google.com/apppasswords)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
#
# Opción B: SendGrid (recomendado, 1000 emails/mes gratis)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxx_tu_api_key
