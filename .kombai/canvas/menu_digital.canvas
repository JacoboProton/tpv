      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=JetBrains+Mono:wght@400;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    background-color: #1a1d23;\n    color: #ffffff;\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .font-mono { font-family: 'JetBrains Mono', monospace; }\n  \n  .glass {\n    background: rgba(37, 40, 48, 0.6);\n    backdrop-filter: blur(12px);\n    -webkit-backdrop-filter: blur(12px);\n    border: 1px solid rgba(255, 255, 255, 0.05);\n  }\n\n  /* Price glow effect */\n  .price-glow {\n    text-shadow: 0 0 10px rgba(176, 94, 94, 0.5);\n  }\n\n  /* Image expansion animation */\n  .dish-item:hover .dish-image,\n  .dish-item:active .dish-image {\n    max-height: 200px;\n    opacity: 1;\n    margin-top: 1rem;\n  }\n</style>\n\n<div class=\"relative min-h-screen flex flex-col pb-24\" data-kid=\"1\">\n  \n  <header class=\"relative h-80 w-full overflow-hidden\" data-kid=\"2\">\n    <video src=\"https://videos.pexels.com/video-files/4765778/4765778-hd_1280_720_25fps.mp4\" poster=\"https://images.pexels.com/videos/4765778/club-drink-drinks-night-4765778.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"absolute inset-0 h-full w-full object-cover\" data-kid=\"3\"></video>\n    <div class=\"absolute inset-0 bg-black/40\" data-kid=\"4\"></div>\n    \n    <div class=\"relative z-10 flex flex-col items-center justify-center h-full px-6 text-center\" data-kid=\"5\">\n      <h1 class=\"text-3xl font-bold tracking-[0.3em] uppercase mb-2\" data-kid=\"6\">Sonora</h1>\n      <div class=\"w-12 h-0.5 bg-[#c4a04a] mb-6\" data-kid=\"7\"></div>\n      \n      \n      <div class=\"glass px-4 py-3 rounded-xl flex items-center gap-4\" data-kid=\"8\">\n        <div class=\"flex flex-col items-start\" data-kid=\"9\">\n          <span class=\"text-[10px] uppercase tracking-widest text-white/60 mb-1\" data-kid=\"10\">Menú del Día</span>\n          <div class=\"flex items-center gap-2\" data-kid=\"11\">\n            <i class=\"ti ti-calendar-clock text-[#c4a04a] text-lg\" data-kid=\"12\"></i>\n            <span class=\"font-mono text-lg font-bold\" data-kid=\"13\">02:45:12</span>\n          </div>\n        </div>\n        <div class=\"w-px h-8 bg-white/10\" data-kid=\"14\"></div>\n        <div class=\"flex flex-col items-end\" data-kid=\"15\">\n          <span class=\"text-[10px] uppercase tracking-widest text-[#b05e5e] mb-1\" data-kid=\"16\">Quedan</span>\n          <div class=\"flex gap-1\" data-kid=\"17\">\n            <div class=\"w-1.5 h-1.5 rounded-full bg-[#b05e5e] animate-pulse\" data-kid=\"18\"></div>\n            <div class=\"w-1.5 h-1.5 rounded-full bg-[#b05e5e]/40\" data-kid=\"19\"></div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </header>\n\n  \n  <section class=\"mt-8 px-6\" data-kid=\"20\">\n    <div class=\"bg-[#252830] border-l-4 border-[#b05e5e] p-5 rounded-r-xl relative overflow-hidden\" data-kid=\"21\">\n      <div class=\"absolute top-0 right-0 p-2 opacity-10\" data-kid=\"22\">\n        <i class=\"ti ti-flame text-6xl\" data-kid=\"23\"></i>\n      </div>\n      <div class=\"relative z-10\" data-kid=\"24\">\n        <h2 class=\"text-sm font-bold uppercase tracking-widest text-[#b05e5e] mb-1\" data-kid=\"25\">Happy Hour Prices Live</h2>\n        <p class=\"text-xs text-white/50 mb-4\" data-kid=\"26\">Solo por tiempo limitado en nuestra selección de cocktails.</p>\n        <div class=\"flex items-baseline gap-3\" data-kid=\"27\">\n          <span class=\"font-mono text-white/30 line-through text-lg\" data-kid=\"28\">12.00€</span>\n          <span class=\"font-mono text-2xl font-bold text-[#b05e5e] price-glow\" data-kid=\"29\">8.50€</span>\n          <span class=\"bg-[#b05e5e]/20 text-[#b05e5e] text-[10px] px-2 py-0.5 rounded font-bold\" data-kid=\"30\">-30%</span>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <div class=\"mt-10 px-6 flex items-center justify-between mb-6\" data-kid=\"31\">\n    <h3 class=\"text-xs font-bold uppercase tracking-[0.2em] text-white/40\" data-kid=\"32\">Platos Destacados</h3>\n    <div class=\"h-px flex-1 bg-white/5 ml-4\" data-kid=\"33\"></div>\n  </div>\n\n  \n  <section class=\"px-6 flex flex-col gap-px bg-[#3e4350]/20\" data-kid=\"34\">\n    \n    <div class=\"dish-item group py-6 bg-[#1a1d23] transition-all cursor-pointer\" data-kid=\"35\">\n      <div class=\"flex justify-between items-start\" data-kid=\"36\">\n        <div class=\"flex-1\" data-kid=\"37\">\n          <div class=\"flex items-center gap-2 mb-1\" data-kid=\"38\">\n            <h4 class=\"text-lg font-bold group-hover:text-[#c4a04a] transition-colors\" data-kid=\"39\">Solomillo al Grill</h4>\n            <div class=\"flex gap-1\" data-kid=\"40\">\n              <i class=\"ti ti-info-circle text-[10px] text-[#b05e5e]\" title=\"Gluten Free\" data-kid=\"41\"></i>\n            </div>\n          </div>\n          <p class=\"text-sm text-white/50 leading-relaxed\" data-kid=\"42\">Steak de ternera madurado 45 días, acompañado de patatas rústicas y chimichurri casero.</p>\n        </div>\n        <div class=\"flex flex-col items-end ml-4\" data-kid=\"43\">\n          <span class=\"font-mono text-lg font-bold text-[#c4a04a]\" data-kid=\"44\">24.50€</span>\n          <button class=\"mt-4 w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:bg-[#c4a04a] hover:border-[#c4a04a] transition-all\" data-kid=\"45\">\n            <i class=\"ti ti-plus text-xs\" data-kid=\"46\"></i>\n          </button>\n        </div>\n      </div>\n      \n      \n      <div class=\"dish-image max-height-0 opacity-0 overflow-hidden transition-all duration-500 ease-in-out\" data-kid=\"47\">\n        <img src=\"https://images.pexels.com/photos/11089587/pexels-photo-11089587.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Solomillo al Grill\" loading=\"lazy\" decoding=\"async\" class=\"w-full h-48 object-cover rounded-xl border border-white/5 shadow-2xl\" data-kid=\"48\">\n        <div class=\"mt-3 flex flex-wrap gap-2\" data-kid=\"49\">\n           <span class=\"text-[10px] uppercase tracking-widest bg-white/5 px-2 py-1 rounded border border-white/10\" data-kid=\"50\">Punto de carne</span>\n           <span class=\"text-[10px] uppercase tracking-widest bg-white/5 px-2 py-1 rounded border border-white/10 text-white/40\" data-kid=\"51\">Extras</span>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"dish-item group py-6 bg-[#1a1d23] transition-all cursor-pointer\" data-kid=\"52\">\n      <div class=\"flex justify-between items-start\" data-kid=\"53\">\n        <div class=\"flex-1\" data-kid=\"54\">\n          <div class=\"flex items-center gap-2 mb-1\" data-kid=\"55\">\n            <h4 class=\"text-lg font-bold group-hover:text-[#c4a04a] transition-colors\" data-kid=\"56\">Tartar de Atún Rojo</h4>\n            <div class=\"flex gap-1\" data-kid=\"57\">\n              <i class=\"ti ti-info-circle text-[10px] text-blue-400\" title=\"Pescado\" data-kid=\"58\"></i>\n            </div>\n          </div>\n          <p class=\"text-sm text-white/50 leading-relaxed\" data-kid=\"59\">Atún de almadraba marinado en soja cítrica, aguacate y perlas de wasabi.</p>\n        </div>\n        <div class=\"flex flex-col items-end ml-4\" data-kid=\"60\">\n          <span class=\"font-mono text-lg font-bold text-[#c4a04a]\" data-kid=\"61\">18.00€</span>\n          <button class=\"mt-4 w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:bg-[#c4a04a] hover:border-[#c4a04a] transition-all\" data-kid=\"62\">\n            <i class=\"ti ti-plus text-xs\" data-kid=\"63\"></i>\n          </button>\n        </div>\n      </div>\n      <div class=\"dish-image max-height-0 opacity-0 overflow-hidden transition-all duration-500 ease-in-out\" data-kid=\"64\">\n        <img src=\"https://images.pexels.com/photos/20350170/pexels-photo-20350170.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Tartar de Atún\" loading=\"lazy\" decoding=\"async\" class=\"w-full h-48 object-cover rounded-xl border border-white/5\" data-kid=\"65\">\n      </div>\n    </div>\n  </section>\n\n  \n  <nav class=\"fixed bottom-6 left-1/2 -translate-x-1/2 w-[90%] z-50\" data-kid=\"66\">\n    <div class=\"glass flex justify-around items-center p-2 rounded-full shadow-2xl\" data-kid=\"67\">\n      <button class=\"flex flex-col items-center p-2 rounded-full bg-[#c4a04a] text-black transition-all\" data-kid=\"68\">\n        <i class=\"ti ti-utensils text-xl\" data-kid=\"69\"></i>\n      </button>\n      <button class=\"flex flex-col items-center p-2 rounded-full text-white/40 hover:text-white transition-all\" data-kid=\"70\">\n        <i class=\"ti ti-beer text-xl\" data-kid=\"71\"></i>\n      </button>\n      <button class=\"flex flex-col items-center p-2 rounded-full text-white/40 hover:text-white transition-all\" data-kid=\"72\">\n        <i class=\"ti ti-coffee text-xl\" data-kid=\"73\"></i>\n      </button>\n      <button class=\"flex flex-col items-center p-2 rounded-full text-white/40 hover:text-white transition-all relative\" data-kid=\"74\">\n        <i class=\"ti ti-flame text-xl\" data-kid=\"75\"></i>\n        <div class=\"absolute top-1 right-1 w-2 h-2 bg-[#b05e5e] rounded-full\" data-kid=\"76\"></div>\n      </button>\n    </div>\n  </nav>\n</div>",
