      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;600;700&family=JetBrains+Mono:wght@400;500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  .dotted-leader {\n    display: flex;\n    align-items: baseline;\n  }\n  .dotted-leader::after {\n    content: \"\";\n    flex-grow: 1;\n    border-bottom: 1.5px dotted #b05e5e;\n    margin: 0 8px;\n    opacity: 0.5;\n  }\n</style>\n\n<div class=\"min-h-screen bg-[#f4efe6] text-[#3d3d3d] font-['Inter'] pb-20 overflow-x-hidden\" data-kid=\"1\">\n  \n  <header class=\"pt-10 pb-6 px-6 text-center\" data-kid=\"2\">\n    <div class=\"flex flex-col items-center\" data-kid=\"3\">\n      <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/fleur-de-lys.svg\" class=\"w-10 h-10 mb-2 opacity-80\" style=\"filter: invert(41%) sepia(31%) saturate(1001%) hue-rotate(314deg) brightness(92%) contrast(85%);\" alt=\"Fleur de lys\" data-kid=\"4\">\n      <h1 class=\"font-['Bebas_Neue'] text-5xl tracking-widest text-[#b05e5e] leading-none uppercase\" data-kid=\"5\">La Sonora</h1>\n      <p class=\"font-['JetBrains_Mono'] text-[10px] tracking-[0.2em] text-[#b0963e] mt-2 uppercase\" data-kid=\"6\">Gastro & Tradición</p>\n      <div class=\"mt-4 flex items-center justify-center gap-4\" data-kid=\"7\">\n        <div class=\"h-px w-12 bg-[#b0963e]/30\" data-kid=\"8\"></div>\n        <span class=\"font-['JetBrains_Mono'] text-xs text-[#b05e5e] font-medium\" data-kid=\"9\">MESA 12</span>\n        <div class=\"h-px w-12 bg-[#b0963e]/30\" data-kid=\"10\"></div>\n      </div>\n    </div>\n  </header>\n\n  \n  <section class=\"px-4 py-4\" data-kid=\"11\">\n    <div class=\"grid grid-cols-3 gap-3\" data-kid=\"12\">\n      \n      <button class=\"flex flex-col items-center p-3 bg-white/50 rounded-sm border border-[#b0963e]/20 shadow-xs active:bg-[#b05e5e] active:text-white transition-colors group\" data-kid=\"13\">\n        <div class=\"w-10 h-10 mb-2 bg-[#f4efe6] rounded-full flex items-center justify-center\" data-kid=\"14\">\n          <i class=\"ti ti-tools-kitchen-2 text-[#b05e5e] group-active:text-white text-xl\" data-kid=\"15\"></i>\n        </div>\n        <span class=\"font-['Bebas_Neue'] text-sm tracking-wider uppercase\" data-kid=\"16\">Entrantes</span>\n      </button>\n      \n      <button class=\"flex flex-col items-center p-3 bg-white border border-[#b05e5e]/30 rounded-sm shadow-sm ring-1 ring-[#b05e5e]/10\" data-kid=\"17\">\n        <div class=\"w-10 h-10 mb-2 bg-[#b05e5e] rounded-full flex items-center justify-center\" data-kid=\"18\">\n          <i class=\"ti ti-meat text-white text-xl\" data-kid=\"19\"></i>\n        </div>\n        <span class=\"font-['Bebas_Neue'] text-sm tracking-wider text-[#b05e5e] uppercase\" data-kid=\"20\">Principales</span>\n      </button>\n      \n      <button class=\"flex flex-col items-center p-3 bg-white/50 rounded-sm border border-[#b0963e]/20 shadow-xs group\" data-kid=\"21\">\n        <div class=\"w-10 h-10 mb-2 bg-[#f4efe6] rounded-full flex items-center justify-center\" data-kid=\"22\">\n          <i class=\"ti ti-bowl-spoon text-[#b05e5e] group-active:text-white text-xl\" data-kid=\"23\"></i>\n        </div>\n        <span class=\"font-['Bebas_Neue'] text-sm tracking-wider uppercase\" data-kid=\"24\">Arroces</span>\n      </button>\n    </div>\n  </section>\n\n  \n  <section class=\"my-6 px-4\" data-kid=\"25\">\n    <div class=\"relative bg-[#b05e5e] p-6 rounded-sm overflow-hidden shadow-lg border-y-2 border-[#b0963e]/40\" data-kid=\"26\">\n      \n      <div class=\"absolute right-[-20px] top-4 flex gap-2 rotate-6 opacity-90 scale-110\" data-kid=\"27\">\n        <img src=\"https://images.pexels.com/photos/26587044/pexels-photo-26587044.jpeg?auto=compress&cs=tinysrgb&w=300&q=80\" class=\"w-32 h-32 object-cover rounded-sm border-2 border-[#f4efe6] shadow-md\" decoding=\"async\" loading=\"lazy\" data-kid=\"28\">\n        <img src=\"https://images.unsplash.com/photo-1553361371-9b22f78e8b1d?auto=format&w=300&q=80&fit=crop\" class=\"w-32 h-32 object-cover rounded-sm border-2 border-[#f4efe6] shadow-md mt-8\" decoding=\"async\" loading=\"lazy\" data-kid=\"29\">\n      </div>\n      \n      <div class=\"relative z-10 w-2/3\" data-kid=\"30\">\n        <div class=\"flex items-center gap-2 mb-2\" data-kid=\"31\">\n          <i class=\"ti ti-sun text-[#f4efe6] text-sm\" data-kid=\"32\"></i>\n          <span class=\"font-['JetBrains_Mono'] text-[10px] text-[#f4efe6] tracking-[0.2em] uppercase\" data-kid=\"33\">Menú del Día</span>\n        </div>\n        <h2 class=\"font-['Bebas_Neue'] text-3xl text-white tracking-wide leading-none mb-1\" data-kid=\"34\">COMBO ARROZ<br data-kid=\"35\">& VINO</h2>\n        <p class=\"text-[#f4efe6]/80 text-xs font-medium italic mb-4\" data-kid=\"36\">Disponible de 13:00 a 16:00</p>\n        <div class=\"inline-block bg-[#f4efe6] px-3 py-1 rounded-xs\" data-kid=\"37\">\n          <span class=\"font-['JetBrains_Mono'] text-lg font-bold text-[#b05e5e]\" data-kid=\"38\">18,50€</span>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"px-6 space-y-10\" data-kid=\"39\">\n    <div class=\"flex flex-col items-center mb-6\" data-kid=\"40\">\n      <div class=\"h-px w-full bg-[#b0963e]/20 mb-2\" data-kid=\"41\"></div>\n      <h3 class=\"font-['Bebas_Neue'] text-2xl tracking-[0.3em] text-[#b05e5e] uppercase\" data-kid=\"42\">Platos Principales</h3>\n      <div class=\"h-px w-full bg-[#b0963e]/20 mt-2\" data-kid=\"43\"></div>\n    </div>\n\n    \n    <div class=\"relative pb-6 border-b border-dashed border-[#b0963e]/30\" data-kid=\"44\">\n      <div class=\"dotted-leader mb-1\" data-kid=\"45\">\n        <span class=\"font-['Bebas_Neue'] text-xl tracking-wide uppercase\" data-kid=\"46\">Paella Valenciana Real</span>\n        <span class=\"font-['JetBrains_Mono'] text-sm font-semibold text-[#b05e5e]\" data-kid=\"47\">16.00</span>\n      </div>\n      <p class=\"text-[11px] leading-relaxed text-[#3d3d3d]/70 pr-10 mb-3\" data-kid=\"48\">\n        Arroz bomba con pollo campero, conejo, garrofó y judía verde, cocinado a la leña para un aroma ahumado tradicional.\n      </p>\n      \n      \n      <div class=\"flex gap-2 mb-4\" data-kid=\"49\">\n        <div class=\"w-5 h-5 flex items-center justify-center bg-[#fde68a]/40 rounded-full\" title=\"Gluten\" data-kid=\"50\">\n          <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/bread.svg\" class=\"w-3 h-3\" data-kid=\"51\">\n        </div>\n        <div class=\"w-5 h-5 flex items-center justify-center bg-[#f87171]/40 rounded-full\" title=\"Crustáceos\" data-kid=\"52\">\n          <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/crab.svg\" class=\"w-3 h-3\" data-kid=\"53\">\n        </div>\n      </div>\n\n      \n      <div class=\"bg-white/40 p-3 rounded-xs border border-[#b0963e]/10\" data-kid=\"54\">\n        <p class=\"text-[9px] font-['JetBrains_Mono'] uppercase tracking-wider text-[#b0963e] mb-2\" data-kid=\"55\">Modificar su elección:</p>\n        <div class=\"flex flex-wrap gap-x-4 gap-y-2\" data-kid=\"56\">\n          <label class=\"flex items-center gap-2 text-[10px] font-medium cursor-pointer\" data-kid=\"57\">\n            <input type=\"checkbox\" class=\"accent-[#b05e5e] w-3 h-3 rounded-none border-[#b05e5e]\" data-kid=\"58\">\n            <span data-kid=\"59\">Sin Cebolla</span>\n          </label>\n          <label class=\"flex items-center gap-2 text-[10px] font-medium cursor-pointer\" data-kid=\"60\">\n            <input type=\"checkbox\" class=\"accent-[#b05e5e] w-3 h-3 rounded-none border-[#b05e5e]\" data-kid=\"61\">\n            <span data-kid=\"62\">Punto de sal +</span>\n          </label>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"relative pb-6 border-b border-dashed border-[#b0963e]/30\" data-kid=\"63\">\n      <div class=\"dotted-leader mb-1\" data-kid=\"64\">\n        <span class=\"font-['Bebas_Neue'] text-xl tracking-wide uppercase\" data-kid=\"65\">Solomillo de Ternera</span>\n        <span class=\"font-['JetBrains_Mono'] text-sm font-semibold text-[#b05e5e]\" data-kid=\"66\">22.50</span>\n      </div>\n      <p class=\"text-[11px] leading-relaxed text-[#3d3d3d]/70 pr-10 mb-3\" data-kid=\"67\">\n        250g de solomillo nacional a la parrilla, acompañado de patatas rústicas y pimientos del padrón.\n      </p>\n      \n      <div class=\"bg-white/40 p-3 rounded-xs border border-[#b0963e]/10\" data-kid=\"68\">\n        <p class=\"text-[9px] font-['JetBrains_Mono'] uppercase tracking-wider text-[#b0963e] mb-2\" data-kid=\"69\">Punto de la carne:</p>\n        <div class=\"flex flex-wrap gap-x-4 gap-y-2\" data-kid=\"70\">\n          <label class=\"flex items-center gap-2 text-[10px] font-medium cursor-pointer\" data-kid=\"71\">\n            <input type=\"radio\" name=\"punto\" class=\"accent-[#b05e5e] w-3 h-3\" data-kid=\"72\">\n            <span data-kid=\"73\">Poco hecho</span>\n          </label>\n          <label class=\"flex items-center gap-2 text-[10px] font-medium cursor-pointer\" data-kid=\"74\">\n            <input type=\"radio\" name=\"punto\" class=\"accent-[#b05e5e] w-3 h-3\" checked data-kid=\"75\">\n            <span data-kid=\"76\">Al punto</span>\n          </label>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <nav class=\"fixed bottom-0 left-0 right-0 bg-[#f4efe6] border-t-2 border-[#b0963e]/30 px-6 py-4 flex justify-between items-center z-50 shadow-[0_-4px_10px_rgba(176,150,62,0.1)]\" data-kid=\"77\">\n    <button class=\"text-[#b05e5e]\" data-kid=\"78\">\n      <i class=\"ti ti-history text-2xl\" data-kid=\"79\"></i>\n    </button>\n    <button class=\"bg-[#b05e5e] text-white px-6 py-2 rounded-xs font-['Bebas_Neue'] tracking-widest flex items-center gap-2 shadow-md\" data-kid=\"80\">\n      <i class=\"ti ti-shopping-cart text-lg\" data-kid=\"81\"></i>\n      MI PEDIDO (2)\n    </button>\n    <button class=\"text-[#b0963e]\" data-kid=\"82\">\n      <i class=\"ti ti-user text-2xl\" data-kid=\"83\"></i>\n    </button>\n  </nav>\n</div>",
