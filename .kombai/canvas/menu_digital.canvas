      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;600;700&family=JetBrains+Mono:wght@500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --color-bg: #f4efe6;\n    --color-surface: #ece6da;\n    --color-sage: #6a8a6c;\n    --color-brass: #b0963e;\n    --color-text: #2c2a26;\n  }\n\n  body {\n    background-color: var(--color-bg);\n    color: var(--color-text);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    padding: 0;\n  }\n\n  .font-bebas { font-family: 'Bebas Neue', cursive; }\n  .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n  .ticket-edge {\n    clip-path: polygon(0% 0%, 100% 0%, 100% 95%, 98% 100%, 96% 95%, 94% 100%, 92% 95%, 90% 100%, 88% 95%, 86% 100%, 84% 95%, 82% 100%, 80% 95%, 78% 100%, 76% 95%, 74% 100%, 72% 95%, 70% 100%, 68% 95%, 66% 100%, 64% 95%, 62% 100%, 60% 95%, 58% 100%, 56% 95%, 54% 100%, 52% 95%, 50% 100%, 48% 95%, 46% 100%, 44% 95%, 42% 100%, 40% 95%, 38% 100%, 36% 95%, 34% 100%, 32% 95%, 30% 100%, 28% 95%, 26% 100%, 24% 95%, 22% 100%, 20% 95%, 18% 100%, 16% 95%, 14% 100%, 12% 95%, 10% 100%, 8% 95%, 6% 100%, 4% 95%, 2% 100%, 0% 95%);\n  }\n\n  .no-scrollbar::-webkit-scrollbar { display: none; }\n  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n  @keyframes pulse {\n    0% { opacity: 1; }\n    50% { opacity: 0.4; }\n    100% { opacity: 1; }\n  }\n  .pulse-dot { animation: pulse 2s infinite; }\n</style>\n\n<div class=\"flex flex-col min-h-screen\" data-kid=\"1\">\n  \n  <header class=\"sticky top-0 z-50 bg-[var(--color-bg)]/90 backdrop-blur-md px-6 py-4 border-b border-black/5 flex justify-between items-center\" data-kid=\"2\">\n    <h1 class=\"font-bebas text-3xl tracking-wide\" data-kid=\"3\">EL RAGOUT</h1>\n    <div class=\"flex items-center gap-2 bg-[var(--color-sage)] text-white px-3 py-1 rounded-full text-xs font-semibold\" data-kid=\"4\">\n      <i class=\"ti ti-table text-base\" data-kid=\"5\"></i>\n      <span data-kid=\"6\">MESA 12</span>\n    </div>\n  </header>\n\n  \n  <section class=\"relative\" data-kid=\"7\">\n    <div class=\"bg-[var(--color-sage)] text-white ticket-edge pt-4 pb-12 px-6 relative overflow-hidden\" data-kid=\"8\">\n      \n      <img src=\"https://images.unsplash.com/photo-1608500218987-0f2b3be34b47?auto=format&w=800&q=80\" alt=\"Ragout\" class=\"absolute inset-0 w-full h-full object-cover opacity-30 mix-blend-overlay\" loading=\"lazy\" decoding=\"async\" data-kid=\"9\">\n      \n      <div class=\"relative z-10\" data-kid=\"10\">\n        <div class=\"flex items-center gap-2 mb-2\" data-kid=\"11\">\n          <span class=\"pulse-dot w-2 h-2 bg-red-400 rounded-full\" data-kid=\"12\"></span>\n          <span class=\"text-[10px] font-bold tracking-[0.2em] uppercase\" data-kid=\"13\">Disponible Ahora</span>\n        </div>\n        <h2 class=\"font-bebas text-5xl leading-none mb-2\" data-kid=\"14\">MENÚ DEL DÍA</h2>\n        <p class=\"text-sm opacity-90 max-w-[200px] mb-6\" data-kid=\"15\">Primero, segundo, bebida y café con el toque de la casa.</p>\n        \n        <div class=\"flex items-center gap-4\" data-kid=\"16\">\n          <div class=\"flex flex-col\" data-kid=\"17\">\n            <span class=\"text-[9px] uppercase font-bold tracking-widest opacity-70\" data-kid=\"18\">Termina en</span>\n            <span class=\"font-mono text-xl\" data-kid=\"19\">02:45:12</span>\n          </div>\n          <div class=\"h-8 w-[1px] bg-white/30\" data-kid=\"20\"></div>\n          <div class=\"flex flex-col\" data-kid=\"21\">\n            <span class=\"text-[9px] uppercase font-bold tracking-widest opacity-70\" data-kid=\"22\">Precio</span>\n            <span class=\"font-mono text-xl text-[var(--color-brass)] font-bold\" data-kid=\"23\">14.50€</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <nav class=\"mt-4 px-6\" data-kid=\"24\">\n    <div class=\"flex gap-3 overflow-x-auto no-scrollbar py-2\" data-kid=\"25\">\n      <button class=\"shrink-0 bg-[var(--color-sage)] text-white px-5 py-2 rounded-full text-sm font-semibold\" data-kid=\"26\">Todos</button>\n      <button class=\"shrink-0 border border-black/10 px-5 py-2 rounded-full text-sm font-semibold opacity-60\" data-kid=\"27\">Entrantes</button>\n      <button class=\"shrink-0 border border-black/10 px-5 py-2 rounded-full text-sm font-semibold opacity-60\" data-kid=\"28\">Principales</button>\n      <button class=\"shrink-0 border border-black/10 px-5 py-2 rounded-full text-sm font-semibold opacity-60\" data-kid=\"29\">Bebidas</button>\n      <button class=\"shrink-0 border border-black/10 px-5 py-2 rounded-full text-sm font-semibold opacity-60\" data-kid=\"30\">Postres</button>\n    </div>\n  </nav>\n\n  \n  <section class=\"mt-8\" data-kid=\"31\">\n    <div class=\"px-6 mb-4 flex justify-between items-end\" data-kid=\"32\">\n      <h3 class=\"font-bebas text-2xl tracking-wide\" data-kid=\"33\">DESTACADOS & COMBOS</h3>\n      <span class=\"text-xs font-bold text-[var(--color-brass)] border-b border-[var(--color-brass)]\" data-kid=\"34\">VER TODOS</span>\n    </div>\n    \n    <div class=\"flex gap-4 overflow-x-auto no-scrollbar px-6 pb-4\" data-kid=\"35\">\n      \n      <div class=\"shrink-0 w-[240px] bg-[var(--color-surface)] rounded-2xl overflow-hidden shadow-lg shadow-black/5\" data-kid=\"36\">\n        <div class=\"relative h-[160px]\" data-kid=\"37\">\n          <img src=\"https://images.unsplash.com/photo-1600891964751-dc0cc8611e47?auto=format&w=800&q=80\" class=\"w-full h-full object-cover\" loading=\"lazy\" decoding=\"async\" data-kid=\"38\">\n          <div class=\"absolute top-3 left-3 bg-red-600 text-white text-[10px] font-bold px-2 py-1 rounded-md flex items-center gap-1\" data-kid=\"39\">\n            <i class=\"ti ti-flame text-xs\" data-kid=\"40\"></i> COMBO AHORRO\n          </div>\n        </div>\n        <div class=\"p-4\" data-kid=\"41\">\n          <h4 class=\"font-semibold text-lg leading-tight mb-1\" data-kid=\"42\">Burger Sonora + Fries</h4>\n          <div class=\"flex justify-between items-center\" data-kid=\"43\">\n            <span class=\"text-xs opacity-60\" data-kid=\"44\">Burger 180g + Rústicas</span>\n            <span class=\"font-mono font-bold text-[var(--color-brass)]\" data-kid=\"45\">12.90€</span>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"shrink-0 w-[240px] bg-[var(--color-surface)] rounded-2xl overflow-hidden shadow-lg shadow-black/5 border-2 border-[var(--color-brass)]/30\" data-kid=\"46\">\n        <div class=\"relative h-[160px]\" data-kid=\"47\">\n          <img src=\"https://images.unsplash.com/photo-1571613316887-6f8d5cbf7ef7?auto=format&w=800&q=80\" class=\"w-full h-full object-cover\" loading=\"lazy\" decoding=\"async\" data-kid=\"48\">\n          <div class=\"absolute top-3 left-3 bg-[var(--color-brass)] text-white text-[10px] font-bold px-2 py-1 rounded-md flex items-center gap-1\" data-kid=\"49\">\n            <i class=\"ti ti-clock text-xs\" data-kid=\"50\"></i> HAPPY HOUR\n          </div>\n        </div>\n        <div class=\"p-4\" data-kid=\"51\">\n          <h4 class=\"font-semibold text-lg leading-tight mb-1\" data-kid=\"52\">Draft Craft Beer 500ml</h4>\n          <div class=\"flex justify-between items-center\" data-kid=\"53\">\n            <div class=\"flex gap-2 items-center\" data-kid=\"54\">\n              <span class=\"text-xs opacity-40 line-through\" data-kid=\"55\">6.50€</span>\n              <span class=\"font-mono font-bold text-[var(--color-brass)]\" data-kid=\"56\">4.50€</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"mt-8 px-6 pb-20\" data-kid=\"57\">\n    <h3 class=\"font-bebas text-2xl tracking-wide mb-4\" data-kid=\"58\">NUESTRA CARTA</h3>\n    \n    <div class=\"flex flex-col gap-4\" data-kid=\"59\">\n      \n      <div class=\"bg-[var(--color-surface)] p-4 rounded-2xl flex gap-4 border border-black/5\" data-kid=\"60\">\n        <div class=\"flex-1\" data-kid=\"61\">\n          <div class=\"flex justify-between items-start mb-1\" data-kid=\"62\">\n            <h4 class=\"font-bold\" data-kid=\"63\">Ragout de Ternera</h4>\n            <span class=\"font-mono text-sm font-bold text-[var(--color-sage)]\" data-kid=\"64\">15.50€</span>\n          </div>\n          <p class=\"text-xs opacity-60 leading-relaxed mb-3\" data-kid=\"65\">Cocinado a fuego lento durante 8 horas con verduras de temporada.</p>\n          <div class=\"flex items-center justify-between\" data-kid=\"66\">\n            <div class=\"flex gap-1.5\" data-kid=\"67\">\n              <span class=\"w-2.5 h-2.5 rounded-full bg-orange-400\" title=\"Gluten\" data-kid=\"68\"></span>\n              <span class=\"w-2.5 h-2.5 rounded-full bg-red-400\" title=\"Lactosa\" data-kid=\"69\"></span>\n            </div>\n            <button class=\"bg-[var(--color-bg)] w-8 h-8 rounded-full flex items-center justify-center border border-black/5 active:scale-95 transition-transform\" data-kid=\"70\">\n              <i class=\"ti ti-plus text-lg\" data-kid=\"71\"></i>\n            </button>\n          </div>\n        </div>\n        <div class=\"w-20 h-20 rounded-xl overflow-hidden shrink-0\" data-kid=\"72\">\n          <img src=\"https://images.unsplash.com/photo-1608500218861-01091cdc501e?auto=format&w=200&q=80\" class=\"w-full h-full object-cover\" loading=\"lazy\" decoding=\"async\" data-kid=\"73\">\n        </div>\n      </div>\n\n      \n      <div class=\"bg-[var(--color-surface)] p-4 rounded-2xl flex gap-4 border border-black/5\" data-kid=\"74\">\n        <div class=\"flex-1\" data-kid=\"75\">\n          <div class=\"flex justify-between items-start mb-1\" data-kid=\"76\">\n            <h4 class=\"font-bold\" data-kid=\"77\">Ensalada de Burrata</h4>\n            <span class=\"font-mono text-sm font-bold text-[var(--color-sage)]\" data-kid=\"78\">11.00€</span>\n          </div>\n          <p class=\"text-xs opacity-60 leading-relaxed mb-3\" data-kid=\"79\">Tomates cherry confitados, pesto de albahaca y piñones tostados.</p>\n          <div class=\"flex items-center justify-between\" data-kid=\"80\">\n            <div class=\"flex gap-1.5\" data-kid=\"81\">\n              <span class=\"w-2.5 h-2.5 rounded-full bg-blue-400\" title=\"Lácteos\" data-kid=\"82\"></span>\n              <span class=\"w-2.5 h-2.5 rounded-full bg-yellow-400\" title=\"Frutos Secos\" data-kid=\"83\"></span>\n            </div>\n            <button class=\"bg-[var(--color-bg)] w-8 h-8 rounded-full flex items-center justify-center border border-black/5 active:scale-95 transition-transform\" data-kid=\"84\">\n              <i class=\"ti ti-plus text-lg\" data-kid=\"85\"></i>\n            </button>\n          </div>\n        </div>\n        <div class=\"w-20 h-20 rounded-xl overflow-hidden shrink-0\" data-kid=\"86\">\n          <img src=\"https://images.unsplash.com/photo-1597740751020-a45809a41967?auto=format&w=200&q=80\" class=\"w-full h-full object-cover\" loading=\"lazy\" decoding=\"async\" data-kid=\"87\">\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <div class=\"fixed bottom-6 left-1/2 -translate-x-1/2 bg-[var(--color-sage)] text-white px-6 py-3 rounded-full shadow-2xl flex items-center gap-4 z-50\" data-kid=\"88\">\n    <div class=\"flex -space-x-2\" data-kid=\"89\">\n      <img src=\"https://i.pravatar.cc/100?u=1\" class=\"w-6 h-6 rounded-full border-2 border-[var(--color-sage)]\" data-kid=\"90\">\n      <img src=\"https://i.pravatar.cc/100?u=2\" class=\"w-6 h-6 rounded-full border-2 border-[var(--color-sage)]\" data-kid=\"91\">\n    </div>\n    <span class=\"text-xs font-bold tracking-wide\" data-kid=\"92\">3 PERSONAS PIDIENDO</span>\n    <div class=\"w-[1px] h-4 bg-white/20\" data-kid=\"93\"></div>\n    <i class=\"ti ti-shopping-cart text-lg\" data-kid=\"94\"></i>\n  </div>\n</div>",
